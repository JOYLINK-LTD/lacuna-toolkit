{
  "name": "lacuna-toolkit-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the Lacuna SDK, CLI, and MCP server.",
  "license": "MIT",
  "author": "Louis Tsang <louistsangjk@gmail.com>",
  "homepage": "https://lacuna.fm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JOYLINK-LTD/lacuna-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/JOYLINK-LTD/lacuna-toolkit/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist",
    "release:login": "npm login --registry=https://registry.npmjs.org/",
    "release:whoami": "npm whoami --registry=https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
