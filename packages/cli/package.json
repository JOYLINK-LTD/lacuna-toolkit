{
  "name": "lacuna-toolkit",
  "version": "0.3.0",
  "description": "Official command-line interface for the Lacuna Music API.",
  "keywords": [
    "lacuna",
    "music",
    "ai",
    "cli",
    "music-generation",
    "ai-music"
  ],
  "license": "MIT",
  "author": "Louis Tsang <louistsangjk@gmail.com>",
  "homepage": "https://lacuna.fm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JOYLINK-LTD/lacuna-toolkit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/JOYLINK-LTD/lacuna-toolkit/issues"
  },
  "type": "module",
  "bin": {
    "lacuna": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "lacuna-sdk": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
